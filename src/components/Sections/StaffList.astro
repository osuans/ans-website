---
interface StaffMember {
  name: string;
  title: string;
  bio?: string;
  imageUrl?: string;
}

export interface Props {
  staff: StaffMember[];
}

const { staff } = Astro.props;
---

<!-- ================= STAFF GRID ================= -->
<section id="staff" class="py-16 bg-white">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl font-bold text-center mb-4">Our Leadership Team</h2>
    <p class="text-center text-gray-600 mb-12">
      Our student leaders and members are dedicated to fostering curiosity, professionalism, and community within the field of nuclear science at Ohio State.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 auto-rows-fr">
      {staff.map(member => (
        <div class="bg-white rounded-lg shadow overflow-hidden flex flex-col h-full">
          <!-- Photo (4:3) -->
          <div class="relative w-full pb-[90%]">
            {member.imageUrl && (
              <img
                src={member.imageUrl}
                alt={member.name}
                class="absolute inset-0 w-full h-full object-cover object-[50%_20%]"
              />
            )}
          </div>
          <div class="p-4 flex flex-col flex-1 justify-between">
            <div>
              <h3 class="text-xl font-semibold mb-1">{member.name}</h3>
              <p class="text-primary-600 mb-2">{member.title}</p>
              <p class="text-gray-700 text-sm">{member.bio}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
