---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostLayout from "../../layouts/PostLayout.astro";
import Button from "../../components/UI/Button.astro";
import PortableText from "../../components/PortableText";
import { sanityClient } from "../../lib/sanity";
import { formatDate, isFutureDate } from "../../utils/dateUtils";
import { parseISO } from "date-fns";
import { CONFIG } from "../../constants";

const { slug } = Astro.params;
if (!slug) return new Response("Not found", { status: 404 });

let entry;
try {
  entry = await sanityClient.fetch(
    `*[_type == "event" && slug.current == $slug && draft != true][0] {
      title, "slug": slug.current, date, endDate, time, location,
      summary, body, tags, registrationLink, registrationRequired, featured,
      "imageUrl": image.asset->url
    }`,
    { slug }
  );
} catch (error) {
  console.error("Failed to fetch event:", error);
  return new Response("Server error", { status: 500 });
}

if (!entry) return new Response("Event not found", { status: 404 });

const formattedDate = formatDate(entry.date);
const formattedEndDate = entry.endDate ? formatDate(entry.endDate) : null;
const isFutureEvent = isFutureDate(entry.endDate || entry.date);
const eventImage = entry.imageUrl || CONFIG.DEFAULTS.EVENT_IMAGE;
---

<BaseLayout
  title={`${entry.title} - Events - American Nuclear Society at OSU`}
  image={{ url: eventImage, alt: entry.title }}
  type="article"
>

  <PostLayout
    title={entry.title}
    image={{ url: eventImage, alt: entry.title }}
    backgroundImage={eventImage}
    date={parseISO(entry.date)}
    tags={entry.tags}
  >
    <!-- Event Details -->
    <div class="bg-gray-50 rounded-lg p-6 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <h3 class="text-lg font-bold mt-0">Date & Time</h3>
          <div class="flex items-start">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 mt-1.5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <div class="mt-0">
              {
                formattedEndDate && formattedEndDate !== formattedDate ? (
                  <p class="m-0">{formattedDate} - {formattedEndDate}</p>
                ) : (
                  <p class="m-0">{formattedDate}</p>
                )
              }
              {entry.time && <p class="mt-[0.002rem]">{entry.time}</p>}
            </div>
          </div>
        </div>

        <div>
          <h3 class="text-lg font-bold mt-0">Location</h3>
          <div class="flex items-start">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 mt-1.5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <p class="mt-0">{entry.location}</p>
          </div>
        </div>
      </div>

      {
        isFutureEvent && (entry.registrationRequired || entry.registrationLink) && (
          <div class="mt-3 pt-6 border-t border-gray-200">
            <h3 class="text-lg font-bold mb-2 mt-0">Registration</h3>
            {entry.registrationRequired && <p class="mb-4">Registration is required for this event.</p>}

            {entry.registrationLink ? (
              <Button href={entry.registrationLink} target="_blank" variant="outline">
                Register Now
              </Button>
            ) : (
              <Button href="/join?subject=Event+Registration" variant="outline">
                Contact Us to Register
              </Button>
            )}
          </div>
        )
      }
    </div>

    <!-- Event Content -->
    <article class="prose prose-lg max-w-none prose-headings:text-gray-900 prose-h1:text-3xl prose-h2:text-2xl prose-h3:text-xl prose-h4:text-lg prose-p:text-gray-700 prose-li:text-gray-700 prose-strong:text-gray-900 prose-a:text-primary-600 hover:prose-a:text-primary-700">
      <PortableText client:load value={entry.body} />
    </article>

    <!-- Action Buttons -->
    <div class="mt-12 flex flex-wrap gap-4">
      {
        isFutureEvent && entry.registrationLink && (
          <Button href={entry.registrationLink} target="_blank" variant="outline">
            Register for This Event
          </Button>
        )
      }

      <Button href="/events" variant="outline">
        Back to All Events
      </Button>

      <Button href="/join" variant="outline">
        Questions? Contact Us
      </Button>
    </div>
  </PostLayout>
</BaseLayout>
